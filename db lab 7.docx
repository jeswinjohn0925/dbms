mysql> CREATE PROCEDURE calculate_bill()
    -> BEGIN
    -> DECLARE done INT DEFAULT 0;
    -> DECLARE v_cust_id INT;
    -> DECLARE v_units INT;
    -> DECLARE v_bill DECIMAL(10,2);
    -> DECLARE cur CURSOR FOR
    -> SELECT cust_id, units FROM electricity;
    -> DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
    -> OPEN cur;
    -> bill_loop: LOOP
    -> FETCH cur INTO v_cust_id, v_units;
    -> IF done = 1 THEN
    -> LEAVE bill_loop;
    -> END IF;
    -> IF v_units <= 100 THEN
    -> SET v_bill = v_units * 1.5;
    -> ELSEIF v_units <= 200 THEN
    -> SET v_bill = (100*1.5) + ((v_units-100)*2.5);
    -> ELSEIF v_units <= 300 THEN
    -> SET v_bill = (100*1.5) + (100*2.5) + ((v_units-200)*4);
    -> ELSE
    -> SET v_bill = (100*1.5) + (100*2.5) + (100*4) + ((v_units-300)*5);
    -> END IF;
    -> UPDATE electricity
    -> SET bill_amount = v_bill
    -> WHERE cust_id = v_cust_id;
    -> END LOOP;
    -> CLOSE cur;
    -> END//
