mysql> DELIMITER //
mysql> CREATE PROCEDURE ReverseNumber(
    -> In n INT
    -> )
    -> BEGIN
    -> DECLARE rev INT DEFAULT 0;
    -> DECLARE temp INT;
    -> SET temp=N;
    -> WHILE temp > 0 DO
    ->         SET rev = rev * 10 + (temp % 10);
    ->         SET temp = FLOOR(temp / 10);
    ->     END WHILE;
    -> 
    ->     SELECT CONCAT('Reversed Number is: ', rev) AS Result;
    -> END //
Query OK, 0 rows affected (0.01 sec)

