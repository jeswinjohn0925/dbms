mysql> DELIMITER //
mysql> CREATE PROCEDURE WITHDRAW_AMOUNT(
    -> IN ACC_ID INT,
    -> IN AMT INT)
    -> BEGIN
    -> DECLARE BAL INT;
    -> SELECT BALANCE INTO BAL
    -> FROM ACCOUNT
    -> WHERE ACCOUNT_ID = ACC_ID;
    -> IF BAL IS NULL THEN
    -> SELECT 'Account does not exist' AS MESSAGE;
    -> ELSEIF BAL - AMT >= 1000 THEN
    -> UPDATE ACCOUNT SET BALANCE = BALANCE -AMT
    -> WHERE ACCOUNT_ID = ACC_ID;
    -> SELECT 'Withdrawal Successful' AS MESSAGE;
    -> ELSE
    -> SELECT 'Minimum balance should be 1000' AS MESSAGE;
    -> END IF;
    -> END //
Query OK, 0 rows affected (0.01 sec)

