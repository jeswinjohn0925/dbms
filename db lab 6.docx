mysql> DELIMITER //
mysql> CREATE FUNCTION sum_of_digits(n INT)
    -> RETURNS INT
    -> DETERMINISTIC
    -> BEGIN
    -> DECLARE total INT DEFAULT 0;
    -> DECLARE temp INT;
    -> SET temp = n;
    -> WHILE temp > 0 DO
    -> SET total = total + MOD(temp,10);
    -> SET temp = FLOOR(temp/10);
    -> END WHILE; 
    -> RETURN total;
    -> END //
mysql> DELIMITER ;
mysql> SELECT sum_of_digits(1234);
