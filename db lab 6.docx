mysql> CREATE PROCEDURE FindFactorial(
    ->     IN n INT
    -> )
    -> BEGIN
    ->     DECLARE i INT DEFAULT 1;
    ->     DECLARE fact BIGINT DEFAULT 1;
    -> 
    ->     WHILE i <= n DO
    ->         SET fact = fact * i;
    ->         SET i = i + 1;
    ->     END WHILE;
    -> 
    ->     SELECT fact AS Factorial;
    -> END //
Query OK, 0 rows affected (0.02 sec)

