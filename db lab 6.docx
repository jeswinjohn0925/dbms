mysql> CREATE PROCEDURE SumSeries(
    -> IN n INT
    -> )
    -> BEGIN
    -> DECLARE total INT DEFAULT 0;
    -> DECLARE i INT DEFAULT 1;
    -> WHILE i <= n DO
    -> SET total = total + i;
    -> SET i = i + 1;
    -> END WHILE;
    -> SELECT CONCAT('sUM IS: ', total) AS Result;
    -> END //
